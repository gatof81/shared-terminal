# ── Shared Terminal — Environment Variables ──────────────────────────────────

# Server port
PORT=3001

# JWT secret — CHANGE THIS for production!
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# CORS — comma-separated origins, or * for all
CORS_ORIGINS=*

# Docker session image name
SESSION_IMAGE=shared-terminal-session

# Where session workspace volumes are stored on the host
WORKSPACE_ROOT=/var/shared-terminal/workspaces

# SQLite database directory
DATA_DIR=./data
