{
  "name": "shared-terminal-backend",
  "version": "1.0.0",
  "description": "Shared terminal service backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "postinstall": "node -e \"const os=require('os'),fs=require('fs'),path=require('path');if(os.platform()==='darwin'){const h=path.join(__dirname,'node_modules','node-pty','prebuilds','darwin-'+os.arch(),'spawn-helper');if(fs.existsSync(h))fs.chmodSync(h,0o755);}\""
  },
  "dependencies": {
    "express": "^4.19.2",
    "node-pty": "^1.1.0",
    "uuid": "^9.0.1",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  }
}
